# Handle line endings automatically for files detected as text 
# and leave binary files untouched.
* text=auto

# Force standard LF for all text files (recommended for Unity)
*.cs text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.meta text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf

# Explicitly declare binary files (so Git doesn't try to fix their line endings)
*.jpg binary
*.png binary
*.psd binary
*.fbx binary
*.wav binary
*.mp3 binary
*.bundle binary